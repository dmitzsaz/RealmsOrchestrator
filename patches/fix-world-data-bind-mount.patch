+DEFAULT_LEVEL_NAME = "world"
+SERVER_DATA_DIR_NAME = "data"
+
 def extract_object_name(s3_url):
     return urlparse(s3_url).path.lstrip('/')
 
@@ -118,4 +121,25 @@ async def zip_and_upload_world(world_dir: str, r2_name: str = None) -> str:
